ENVIRONMENT=production

# One shared password used to sign in. No usernames, no user table.
APP_PASSWORD=change-me

# Secret used to sign the session cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me

# Shared secret required on internal API calls via the x-internal-secret header
# (used by n8n webhooks calling back into this app).
MEDIA_APP_INTERNAL_SECRET=change-me

DATABASE_URL=postgresql+psycopg://msl:msl@msl-insights-db:5432/msl_insights

N8N_BASE_URL=https://n8n.aiexperiments.eu

# Production classification webhook (RETAIL 02 workflow). DeepSeek is called inside n8n only.
N8N_CLASSIFICATION_WEBHOOK_URL=https://n8n.aiexperiments.eu/webhook/retail-media/classify
N8N_REQUEST_TIMEOUT_SECONDS=15

# Directory where uploaded workbooks are stored (overridden to /app/data/uploads by docker-compose)
UPLOAD_ROOT_DIR=data/uploads
MAX_UPLOAD_SIZE_BYTES=104857600

# Postgres container settings (docker-compose)
POSTGRES_USER=msl
POSTGRES_PASSWORD=msl
POSTGRES_DB=msl_insights
